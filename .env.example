NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only. Nunca use NEXT_PUBLIC_OPENAI_API_KEY.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Opcionais para classificar intencoes do Assistente IA. Sem essas chaves, o assistente usa regras locais.
# Valores aceitos em AI_PROVIDER: gemini, openrouter, groq.
AI_PROVIDER=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-flash-1.5
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Google OAuth por usuario. Server-side only; nao prefixar com NEXT_PUBLIC.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_TOKEN_ENCRYPTION_KEY=

# Protege endpoints de cron. Use header Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# Opcionais para importacao de bases geograficas. Drive e origem bruta, nao banco de consulta em tempo real.
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# Somente para scripts locais/admin de importacao geografica. Nunca use no frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Server-side only para API oficial MapBiomas Alerta. Nunca use NEXT_PUBLIC_.
MAPBIOMAS_ALERT_API_URL=https://plataforma.alerta.mapbiomas.org/api/v2/graphql
MAPBIOMAS_ALERT_EMAIL=
MAPBIOMAS_ALERT_PASSWORD=
MAPBIOMAS_ALERT_TOKEN=

# Opcionais para Playwright E2E em banco Supabase de teste.
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
E2E_RUN_MUTATION_TESTS=false

# Nunca use a service role key no frontend.
